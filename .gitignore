node_modules/
dist/
.turbo/
*.tsbuildinfo
.loom/
*.log

# npm-package assembly output (scripts/build-npm-package.mjs) + the packed tarball
dist-npm/
*.tgz

# Playwright-MCP artifact dir that appears at the repo root
.playwright-mcp/

# @playwright/test e2e harness (packages/web/e2e) run artifacts
test-results/
playwright-report/
blob-report/

# Local spike scratch dir (was only in .git/info/exclude → unprotected on a fresh clone)
spike/

# Python bytecode (packages/daemon/assets/python/*.py run live by the daemon)
__pycache__/
*.pyc

# Transient verify-run SQLite DBs (migration/backup verification) + their sidecars
tmp-*verify.db*

# Ad-hoc browser-verification screenshots written to the repo root (cwd) —
# root-only so tracked assets under docs/, packages/**, site/** are untouched
/*.png

# Dev-only project-local skills for THIS repo's own self-hosting Claude Code sessions — a mix of the
# canonical packages/daemon/assets/skills/** (refreshed here by scripts/sync-claude-skills.mjs on every
# daemon build; never hand-edit those) and any personal, never-bundled skill dirs a dev/owner keeps here
# too (e.g. ideate). Never commit this dir.
/.claude/skills/
