    "test:diff": "node --experimental-strip-types test/diff.mjs",
    "test:companion": "node --experimental-strip-types test/companion.mjs",
    "test:companion-chat": "node --experimental-strip-types test/companionChat.mjs",
    "test:archive-invalidate": "node --experimental-strip-types test/archive-invalidate.mjs",
