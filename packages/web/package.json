    "test:sessions": "node --experimental-strip-types test/sessions.mjs",
    "test:column-sort": "node --experimental-strip-types test/column-sort.mjs",
    "test:fleet": "node --experimental-strip-types test/fleet.mjs",
    "test:nav-companion-gating": "node --experimental-strip-types test/nav-companion-gating.mjs",
    "test:orchestration-no-global-cluster": "node --experimental-strip-types test/orchestration-no-global-cluster.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview"
