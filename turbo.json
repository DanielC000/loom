{
  "$schema": "https://turbo.build/schema.json",
  // Key EVERY task's cache on install-state: a change to the root lockfile (a dep add/bump) invalidates
  // all build caches, so a stale FULL TURBO replay can never serve a build that predates the dependency
  // change. turbo already tracks the lockfile implicitly; declaring it makes the dep→rebuild contract
  // explicit and version-independent. (The daemon-deploy build additionally `--force`s — see
  // packages/daemon/src/orchestration/restart.ts › deployBuildSteps — so its cache is fully defeated.)
  "globalDependencies": ["pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@loom/daemon#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      // @loom/daemon's build script runs scripts/sync-claude-skills.mjs (outside this package's own
      // file tree), so it needs its own inputs entry keying the cache on that script too — otherwise a
      // script-only change is invisible to turbo and a bare `pnpm build` can replay a stale cache hit
      // without re-running the sync. $TURBO_DEFAULT$ preserves the normal git-tracked-files inputs.
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/scripts/sync-claude-skills.mjs"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
